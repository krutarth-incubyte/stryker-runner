<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.nicetester.stryker</id>
    <name>Stryker Runner</name>
    <vendor>nicetester</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.StrykerBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Stryker Output"
                    anchor="bottom"
                    factoryClass="com.github.nicetester.stryker.runner.StrykerToolWindowFactory"
                    canCloseContents="true"/>
        <notificationGroup id="Stryker Runner"
                           displayType="BALLOON"/>
        <externalAnnotator language=""
                           implementationClass="com.github.nicetester.stryker.annotator.MutantAnnotator"/>
    </extensions>

    <actions>
        <action id="com.github.nicetester.stryker.action.RunStrykerAction"
                class="com.github.nicetester.stryker.action.RunStrykerAction"
                text="Run Stryker"
                icon="/icons/runStryker.svg"
                description="Run Stryker mutation testing on the selected file or folder">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
        <action id="com.github.nicetester.stryker.action.FetchCiReportAction"
                class="com.github.nicetester.stryker.action.FetchCiReportAction"
                text="Fetch Stryker Results from CI"
                icon="/icons/fetchCiReport.svg"
                description="Download mutation report from the GitHub Actions PR workflow">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
